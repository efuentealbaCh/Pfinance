generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model account_types {
  id            String          @id @db.Uuid
  name          String          @unique(map: "account_types_name_unique") @db.VarChar(255)
  created_at    DateTime?       @db.Timestamp(0)
  updated_at    DateTime?       @db.Timestamp(0)
  user_accounts user_accounts[]
}

model banks {
  id            String          @id @db.Uuid
  name          String          @unique(map: "banks_name_unique") @db.VarChar(255)
  logo          String?         @db.VarChar(255)
  created_at    DateTime?       @db.Timestamp(0)
  updated_at    DateTime?       @db.Timestamp(0)
  user_accounts user_accounts[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model budgets {
  id          String     @id @db.Uuid
  user_id     BigInt
  category_id String     @db.Uuid
  amount      Decimal    @db.Decimal(15, 2)
  period      String     @default("monthly") @db.VarChar(255)
  created_at  DateTime?  @db.Timestamp(0)
  updated_at  DateTime?  @db.Timestamp(0)
  categories  categories @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "budgets_category_id_foreign")
  users       users      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "budgets_user_id_foreign")

  @@unique([user_id, category_id, period], map: "budgets_user_id_category_id_period_unique")
}

model cache {
  key        String @id @db.VarChar(255)
  value      String
  expiration Int

  @@index([expiration], map: "cache_expiration_index")
}

model cache_locks {
  key        String @id @db.VarChar(255)
  owner      String @db.VarChar(255)
  expiration Int

  @@index([expiration], map: "cache_locks_expiration_index")
}

model categories {
  id           String         @id @db.Uuid
  name         String         @db.VarChar(255)
  icon         String?        @db.VarChar(255)
  color        String?        @db.VarChar(255)
  created_at   DateTime?      @db.Timestamp(0)
  updated_at   DateTime?      @db.Timestamp(0)
  budgets      budgets[]
  transactions transactions[]
}

model failed_jobs {
  id         BigInt   @id @default(autoincrement())
  uuid       String   @unique(map: "failed_jobs_uuid_unique") @db.VarChar(255)
  connection String
  queue      String
  payload    String
  exception  String
  failed_at  DateTime @default(now()) @db.Timestamp(0)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model group_user {
  id         BigInt    @id @default(autoincrement())
  group_id   BigInt
  user_id    BigInt
  status     String    @default("pending") @db.VarChar(255)
  role       String    @default("member") @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  groups     groups    @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "group_user_group_id_foreign")
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "group_user_user_id_foreign")
}

model groups {
  id           BigInt         @id @default(autoincrement())
  name         String         @db.VarChar(255)
  description  String?
  created_by   BigInt
  created_at   DateTime?      @db.Timestamp(0)
  updated_at   DateTime?      @db.Timestamp(0)
  group_user   group_user[]
  users        users          @relation(fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "groups_created_by_foreign")
  shared_debts shared_debts[]
}

model job_batches {
  id             String  @id @db.VarChar(255)
  name           String  @db.VarChar(255)
  total_jobs     Int
  pending_jobs   Int
  failed_jobs    Int
  failed_job_ids String
  options        String?
  cancelled_at   Int?
  created_at     Int
  finished_at    Int?
}

model jobs {
  id           BigInt @id @default(autoincrement())
  queue        String @db.VarChar(255)
  payload      String
  attempts     Int    @db.SmallInt
  reserved_at  Int?
  available_at Int
  created_at   Int

  @@index([queue], map: "jobs_queue_index")
}

model migrations {
  id        Int    @id @default(autoincrement())
  migration String @db.VarChar(255)
  batch     Int
}

model password_reset_tokens {
  email      String    @id @db.VarChar(255)
  token      String    @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
}

model personal_access_tokens {
  id             BigInt    @id @default(autoincrement())
  tokenable_type String    @db.VarChar(255)
  tokenable_id   BigInt
  name           String
  token          String    @unique(map: "personal_access_tokens_token_unique") @db.VarChar(64)
  abilities      String?
  last_used_at   DateTime? @db.Timestamp(0)
  expires_at     DateTime? @db.Timestamp(0)
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)

  @@index([expires_at], map: "personal_access_tokens_expires_at_index")
  @@index([tokenable_type, tokenable_id], map: "personal_access_tokens_tokenable_type_tokenable_id_index")
}

model push_subscriptions {
  id                BigInt    @id @default(autoincrement())
  subscribable_type String    @db.VarChar(255)
  subscribable_id   BigInt
  endpoint          String    @unique(map: "push_subscriptions_endpoint_unique") @db.VarChar(500)
  public_key        String?   @db.VarChar(255)
  auth_token        String?   @db.VarChar(255)
  content_encoding  String?   @db.VarChar(255)
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)

  @@index([subscribable_type, subscribable_id], map: "push_subscriptions_subscribable_morph_idx")
}

model savings_goals {
  id             String    @id @db.Uuid
  user_id        BigInt
  name           String    @db.VarChar(255)
  target_amount  Decimal   @db.Decimal(15, 2)
  current_amount Decimal   @default(0) @db.Decimal(15, 2)
  deadline       DateTime? @db.Date
  icon           String?   @db.VarChar(255)
  color          String?   @db.VarChar(255)
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)
  users          users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "savings_goals_user_id_foreign")
}

model sessions {
  id            String  @id @db.VarChar(255)
  user_id       BigInt?
  ip_address    String? @db.VarChar(45)
  user_agent    String?
  payload       String
  last_activity Int

  @@index([last_activity], map: "sessions_last_activity_index")
  @@index([user_id], map: "sessions_user_id_index")
}

model shared_debt_splits {
  id             BigInt       @id @default(autoincrement())
  shared_debt_id BigInt
  user_id        BigInt
  percentage     Decimal      @db.Decimal(5, 2)
  amount_owed    Decimal      @db.Decimal(15, 2)
  is_paid        Boolean      @default(false)
  created_at     DateTime?    @db.Timestamp(0)
  updated_at     DateTime?    @db.Timestamp(0)
  shared_debts   shared_debts @relation(fields: [shared_debt_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "shared_debt_splits_shared_debt_id_foreign")
  users          users        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "shared_debt_splits_user_id_foreign")
}

model shared_debts {
  id                 BigInt               @id @default(autoincrement())
  group_id           BigInt
  created_by         BigInt
  title              String               @db.VarChar(255)
  amount             Decimal              @db.Decimal(15, 2)
  date               DateTime             @db.Date
  transaction_id     String?              @db.Uuid
  created_at         DateTime?            @db.Timestamp(0)
  updated_at         DateTime?            @db.Timestamp(0)
  shared_debt_splits shared_debt_splits[]
  users              users                @relation(fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "shared_debts_created_by_foreign")
  groups             groups               @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "shared_debts_group_id_foreign")
  transactions       transactions?        @relation(fields: [transaction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model transaction_logs {
  id             String       @id @db.Uuid
  transaction_id String       @db.Uuid
  user_id        BigInt
  action         String       @db.VarChar(255)
  payload_before Json?
  payload_after  Json?
  ip_address     String?      @db.VarChar(45)
  user_agent     String?
  created_at     DateTime     @default(now()) @db.Timestamp(0)
  transactions   transactions @relation(fields: [transaction_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "transaction_logs_transaction_id_foreign")
  users          users        @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "transaction_logs_user_id_foreign")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model transactions {
  id               String             @id @db.Uuid
  user_id          BigInt
  user_account_id  String             @db.Uuid
  target_account_id String?           @db.Uuid
  category_id      String?            @db.Uuid
  amount           Decimal            @db.Decimal(15, 2)
  description      String?
  date             DateTime           @db.Date
  type             String             @db.VarChar(255)
  is_shared        Boolean            @default(true)
  created_at       DateTime?          @db.Timestamp(0)
  updated_at       DateTime?          @db.Timestamp(0)
  transaction_logs transaction_logs[]
  categories       categories?        @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "transactions_category_id_foreign")
  user_accounts    user_accounts      @relation("transactions_user_account", fields: [user_account_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "transactions_user_account_id_foreign")
  target_accounts  user_accounts?     @relation("transactions_target_account", fields: [target_account_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users              @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "transactions_user_id_foreign")
  shared_debts     shared_debts[]
}

model user_accounts {
  id              String         @id @db.Uuid
  user_id         BigInt
  bank_id         String         @db.Uuid
  account_type_id String         @db.Uuid
  identifier      String?        @db.VarChar(255)
  balance         Decimal        @default(0) @db.Decimal(15, 2)
  created_at      DateTime?      @db.Timestamp(0)
  updated_at      DateTime?      @db.Timestamp(0)
  transactions    transactions[] @relation("transactions_user_account")
  transactions_as_target transactions[] @relation("transactions_target_account")
  account_types   account_types  @relation(fields: [account_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_accounts_account_type_id_foreign")
  banks           banks          @relation(fields: [bank_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_accounts_bank_id_foreign")
  users           users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_accounts_user_id_foreign")
}

model users {
  id                 BigInt               @id @default(autoincrement())
  name               String               @db.VarChar(255)
  email              String               @unique(map: "users_email_unique") @db.VarChar(255)
  email_verified_at  DateTime?            @db.Timestamp(0)
  password           String               @db.VarChar(255)
  remember_token     String?              @db.VarChar(100)
  created_at         DateTime?            @db.Timestamp(0)
  updated_at         DateTime?            @db.Timestamp(0)
  budgets            budgets[]
  group_user         group_user[]
  groups             groups[]
  savings_goals      savings_goals[]
  shared_debt_splits shared_debt_splits[]
  shared_debts       shared_debts[]
  transaction_logs   transaction_logs[]
  transactions       transactions[]
  user_accounts      user_accounts[]
}
